{
  "name": "v2board-frontend",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24.11.0",
    "pnpm": ">=11.11.0"
  },
  "scripts": {
    "dev:admin": "pnpm --filter @v2board/admin dev",
    "dev:user": "pnpm --filter @v2board/user dev",
    "build": "pnpm -r --parallel build",
    "build:admin": "pnpm --filter @v2board/admin build",
    "build:deploy": "node scripts/build-deploy.mjs",
    "build:user": "pnpm --filter @v2board/user build",
    "audit:deps": "knip",
    "audit:source": "node scripts/frontend-source-audit.mjs",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,css}\"",
    "test": "node --test scripts/*.test.mjs tests/lib/dialect/*.test.mjs && vitest run",
    "test:coverage": "node --test scripts/*.test.mjs tests/lib/dialect/*.test.mjs && vitest run --coverage",
    "visual-smoke": "node scripts/visual-smoke.mjs",
    "parity": "playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint-react/eslint-plugin": "^5.14.10",
    "@eslint/js": "^10.0.1",
    "@hey-api/openapi-ts": "catalog:",
    "@playwright/test": "^1.61.1",
    "@tanstack/eslint-plugin-query": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "knip": "catalog:",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.63.0",
    "vitest": "catalog:"
  }
}
