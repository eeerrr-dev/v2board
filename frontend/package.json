{
  "name": "v2board-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.9.0"
  },
  "scripts": {
    "dev:admin": "pnpm --filter @v2board/admin dev",
    "dev:user": "pnpm --filter @v2board/user dev",
    "build": "pnpm -r --parallel build",
    "build:admin": "pnpm --filter @v2board/admin build",
    "build:deploy": "node scripts/build-deploy.mjs",
    "build:user": "pnpm --filter @v2board/user build",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\"",
    "test": "pnpm -r --parallel test",
    "visual-parity": "node scripts/visual-parity.mjs",
    "visual-smoke": "node scripts/visual-smoke.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
