{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "arrowParens": "always",
  "endOfLine": "lf",
  "plugins": ["prettier-plugin-tailwindcss"],
  "tailwindFunctions": ["cn", "cva"],
  "overrides": [
    {
      "files": "apps/user/**",
      "options": { "tailwindStylesheet": "apps/user/src/styles/globals.css" }
    },
    {
      "files": "apps/admin/**",
      "options": { "tailwindStylesheet": "apps/admin/src/styles/globals.css" }
    },
    {
      "files": "packages/ui/**",
      "options": { "tailwindStylesheet": "apps/user/src/styles/globals.css" }
    }
  ]
}
